---
export interface Props {
  title?: string;
}

const { title = "Hey Investment — Backtest Dashboard" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: #1a1a2e;
        color: #e0e0e0;
        min-height: 100vh;
      }

      nav {
        background: #16213e;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #0f3460;
      }

      nav .brand {
        font-size: 1.25rem;
        font-weight: 700;
        color: #00b894;
        letter-spacing: 0.5px;
      }

      nav .brand span {
        font-weight: 300;
        color: #636e72;
      }

      nav a {
        color: #636e72;
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s;
      }

      nav a:hover {
        color: #00b894;
      }

      main {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1.5rem;
      }

      .card {
        background: #16213e;
        border-radius: 12px;
        padding: 1.5rem;
        border: 1px solid #0f3460;
      }

      h2 {
        font-size: 1.1rem;
        color: #b2bec3;
        margin-bottom: 1rem;
        font-weight: 500;
      }

      .section {
        margin-bottom: 2rem;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="brand">Hey <span>Investment</span></div>
      <a href="https://github.com" target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
